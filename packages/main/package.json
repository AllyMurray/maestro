{
  "name": "@maestro/main",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "test": "vitest run",
    "pretest:unit": "npm rebuild better-sqlite3 --update-binary",
    "test:unit": "vitest run --exclude '**/*.integration.test.ts'",
    "test:integration": "sh -c 'files=$(rg --files -g \"*.integration.test.ts\" src); [ -n \"$files\" ] && vitest run $files || vitest run --passWithNoTests'",
    "test:coverage": "vitest run --coverage --exclude '**/*.integration.test.ts'",
    "test:watch": "vitest",
    "postinstall": "chmod +x ./node_modules/.pnpm/node-pty@*/node_modules/node-pty/prebuilds/darwin-*/spawn-helper ./node_modules/node-pty/prebuilds/darwin-*/spawn-helper 2>/dev/null; electron-rebuild -m ."
  },
  "dependencies": {
    "@maestro/shared": "workspace:*",
    "better-sqlite3": "^11.8.1",
    "node-pty": "^1.1.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "electron": "^35.1.2",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  }
}
